<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.control.TextField?>
<!-- 💡 Added standard static property import requirement context -->
<?import javafx.scene.control.TableView?> 
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" spacing="0" styleClass="root" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.videodownloader.controller.VideoMainController">
   <!-- TOOLBAR -->
   <ToolBar styleClass="tool-bar">
        <Button onAction="#addVideoUrl" styleClass="toolbar-btn, btn-add">
            <tooltip><Tooltip text="Add Video URL" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xe494;" />
            </graphic>
        </Button>

        <Separator orientation="VERTICAL" />

        <Button onAction="#handleStopAll" styleClass="toolbar-btn, btn-stop">
            <tooltip><Tooltip text="Stop All" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xf04d;" />
            </graphic>
        </Button>

        <Button onAction="#resumeAll" styleClass="toolbar-btn, btn-resume">
            <tooltip><Tooltip text="Resume All" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xf04b;" />
            </graphic>
        </Button>

        <Separator orientation="VERTICAL"/>
        
        <Button onAction="#handleClearCompleted" styleClass="toolbar-btn, btn-clear">
            <tooltip><Tooltip text="Clear completed" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xf2ed;" />
            </graphic>
        </Button>

        <!-- 💡 NEW: Clear Entire Table Button (Trash icon with an exclamation or alternate glyph) -->
        <Button onAction="#handleClearAll" styleClass="toolbar-btn, btn-clear-all">
            <tooltip><Tooltip text="Clear Table" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xf1f8;" /> <!-- FontAwesome trash-alt or alternate empty glyph -->
            </graphic>
        </Button>


        <Separator orientation="VERTICAL" />

        <Button onAction="#openVideosFolder" styleClass="toolbar-btn, btn-folder">
            <tooltip><Tooltip text="Open Downloads Folder" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xf07c;" />
            </graphic>
        </Button>

        <Separator orientation="VERTICAL"/>

        <Button onAction="#handleToggleTheme" styleClass="toolbar-btn, btn-theme">
            <tooltip><Tooltip text="Toggle dark/light theme" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xf0eb;" />
            </graphic>
        </Button>

        <Separator orientation="VERTICAL"/>

        <!-- Fixed Class and Tooltip here -->
        <Button onAction="#handleOpenScheduler" styleClass="toolbar-btn, btn-scheduler">
            <tooltip><Tooltip text="Open Queue Scheduler" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xf34e;" />
            </graphic>
        </Button>

        <Region HBox.hgrow="ALWAYS" />

        <Separator orientation="VERTICAL"/>

        <Button onAction="#openSettings" styleClass="toolbar-btn, btn-settings">
            <tooltip><Tooltip text="Open Settings" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xf7d9;" />
            </graphic>
        </Button>
        
        <Separator orientation="VERTICAL"/>
        
        <Button onAction="#buyCoffee" styleClass="toolbar-btn, btn-coffee">
            <tooltip><Tooltip text="Support the dev" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xf7b6;" />
            </graphic>
        </Button>

        <Separator orientation="VERTICAL"/>
        <Button onAction="#handleExit" styleClass="toolbar-btn, btn-exit">
            <tooltip><Tooltip text="Close application" /></tooltip>
            <graphic>
                <Label styleClass="icon-font-white" text="&#xf011;" />
            </graphic>
        </Button>

        
   </ToolBar>

   <!-- 2. NEW: Dedicated Search Panel Row -->
    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-panel-row">
        <HBox alignment="CENTER" spacing="8" styleClass="search-container" HBox.hgrow="ALWAYS">
            <Label styleClass="icon-font-muted" text="&#xf002;" /> <!-- FontAwesome search icon -->
            <TextField fx:id="searchField" promptText="Search downloads by title..." styleClass="search-field" HBox.hgrow="ALWAYS" />
        </HBox>
    </HBox>


   <!-- TABLE -->
   <!-- 💡 FIXED: Added constrained resize policy allocation right here -->
   <TableView fx:id="table" styleClass="table-view" VBox.vgrow="ALWAYS">
       <columnResizePolicy>
           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
       </columnResizePolicy>
       <columns>
           <!-- Note: These prefWidths now function as structural percentage proportions -->
           <TableColumn fx:id="iconCol" minWidth="40" prefWidth="45" text="" />
           <TableColumn fx:id="titleCol" minWidth="150" prefWidth="250" text="Title" />
           <TableColumn fx:id="qualityCol" minWidth="70" prefWidth="90" text="Quality" />
           <TableColumn fx:id="sizeCol" minWidth="70" prefWidth="90" text="Size" />
           <TableColumn fx:id="progressCol" minWidth="120" prefWidth="160" text="Progress" />
           <TableColumn fx:id="speedCol" minWidth="80" prefWidth="100" text="Speed" />
           <TableColumn fx:id="etaCol" minWidth="70" prefWidth="80" text="ETA" />
           <TableColumn fx:id="statusCol" minWidth="80" prefWidth="100" text="Status" />
       </columns>
   </TableView>

   <!-- STATUS BAR -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="status-bar">
        <padding><Insets bottom="6" left="16" right="16" top="6" /></padding>
        <Label fx:id="activeLabel" styleClass="status-bar-label" text="Active: 0" />
        <Label fx:id="totalLabel" styleClass="status-bar-label" text="Completed: 0 / 0" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="ytdlpStatusLabel" styleClass="status-bar-label, status-bar-system" text="Checking yt-dlp…" />
    </HBox>

</VBox>